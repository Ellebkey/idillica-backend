# Configuración local de desarrollo. Para producción ver .env.prod.
APP_ENV=development
PORT=4051

# Firma de los JWT — usa una cadena larga y aleatoria en producción
JWT_SECRET=change-me-to-a-real-secret

# Origen permitido por CORS (el frontend Vite en dev)
FRONTEND_URL=http://localhost:5273

# Verificación de correo (false = las cuentas quedan listas sin Resend)
AUTH_REQUIRE_EMAIL_VERIFICATION=false

# Correos transaccionales (opcional)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@idilica.app

# PostgreSQL
SQL_HOST=localhost
SQL_DB=idilica_go
SQL_USER=postgres
SQL_PASSWORD=change-me
SQL_PORT=5432

# Redis (tokens de refresco)
REDIS_URL=redis://localhost:6379
