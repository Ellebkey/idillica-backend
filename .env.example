# Mismos nombres de variables que idilica-backend (Node): puedes copiar aquel
# .env y solo cambiar PORT y SQL_DB para correr ambos backends a la vez.
#
# Producción (droplet, en ~/secrets/.env.idilica):
#   NODE_ENV=production · PORT=8101 · FRONTEND_URL=https://idilica.joelbarranco.io
NODE_ENV=development
PORT=4051

# Firma de los JWT. Usa el MISMO valor que el backend Node y los tokens/sesiones
# son intercambiables entre ambos.
JWT_SECRET=change-me-to-a-real-secret

# Origen permitido por CORS (el frontend Vite en dev)
FRONTEND_URL=http://localhost:5273

# Verificación de correo (false = las cuentas quedan listas sin Resend)
AUTH_REQUIRE_EMAIL_VERIFICATION=false

# Correos transaccionales (opcional)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@idilica.app

# PostgreSQL — base de datos PROPIA (idilica_go) para no chocar con la del Node
SQL_HOST=localhost
SQL_DB=idilica_go
SQL_USER=postgres
SQL_PASSWORD=change-me
SQL_PORT=5432

# Redis (tokens de refresco)
REDIS_URL=redis://localhost:6379
